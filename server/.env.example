# Optional: Outlook ICS calendar URL used to fetch meetings
# Leave empty to disable Outlook meetings.
OUTLOOK_ICS_URL=

# Optional: Supabase/Postgres connection string.
# If set, the server stores all data in Supabase (multi-device).
# If empty, it falls back to the local SQLite file (server/agenda.db).
# Get it from: Supabase dashboard -> Settings -> Database -> Connection string (URI)
# Use the "Session pooler" variant (port 5432) for IPv4 networks.
# DATABASE_URL=postgresql://postgres.xxxx:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres
DATABASE_URL=
